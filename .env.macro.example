# Copy to .env.macro and fill in values. Never commit .env.macro.
#
# Used by the daily macro briefing job (pnpm macro:briefing / PM2 accumula-bot-macro-briefing).
# Easiest setup: copy your .env to .env.macro, then change the LLM_* block below to OpenAI (or another
# web-capable provider). All other vars must still satisfy loadConfig() — same requirements as .env.

# LLM provider — OpenAI Responses API with web search (do not use ollama here)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5
LLM_API_KEY=
# Macro briefing uses POST /v1/responses with web_search + reasoning=high (no output token cap).
# LLM_TEMPERATURE is ignored for gpt-5.x on api.openai.com (fixed default)

# Assets (must match your trading .env)
ASSET_TO_ACCUMULATE=BTC
ASSET_TRADEABLE=BTC,ETH,SOL,USDC
ASSET_STARTING=USDC

# Storage — same DB as the trading bot (briefings are read by hourly runs)
DATABASE_PATH=data/accumula.db

# Required by loadConfig() even though this job does not scrape Twitter
CLOUDAMQP_URL=amqp://localhost

# Telegram — daily briefing notification (macro text + portfolio summary)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market data / optional sections — copy from .env if you use non-defaults
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# COINGECKO_API_KEY=
# PREDICTION_MARKETS_ENABLED=false
# SOCIAL_MEDIA_ENABLED=false
