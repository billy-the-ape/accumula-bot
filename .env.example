# Copy to .env and fill in values. Never commit .env.

# Exchange API (Phase 4 — live trading)
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=

# LLM provider (Phase 1+)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
# LLM_MODEL=qwen3:8b 
LLM_MODEL=qwen3:8b
# LLM_API_KEY=
#
# ollama — local Ollama (default)
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://127.0.0.1:11434
#   LLM_MODEL=qwen3:8b
#
# openai_compatible — OpenAI and other OpenAI-compatible APIs
#   LLM_PROVIDER=openai_compatible
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-5.5
#   LLM_API_KEY=
#
# anthropic — Anthropic Messages API 
#   LLM_PROVIDER=anthropic
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   LLM_API_KEY=

# Assets
ASSET_TO_ACCUMULATE=BTC
ASSET_TRADEABLE=BTC,ETH,SOL,USDC
ASSET_STARTING=USDC

# Storage (Phase 2+)
DATABASE_PATH=data/accumula.db
# Daily macro briefing job uses a separate env file: cp .env.macro.example .env.macro
# (OpenAI web search). Same DATABASE_PATH so briefings are visible to trading runs.

# Market data (Phase 2+)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

CLOUDAMQP_URL=

PREDICTION_MARKETS_ENABLED=true
SOCIAL_MEDIA_ENABLED=true