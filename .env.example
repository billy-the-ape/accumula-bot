# Copy to .env and fill in values. Never commit .env.

# Exchange API (Phase 4 — live trading)
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=

# LLM provider (Phase 1+)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
# LLM_MODEL=qwen3:8b 
LLM_MODEL=qwen3:8b
# LLM_API_KEY=
#
# ollama — local Ollama (default)
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://127.0.0.1:11434
#   LLM_MODEL=qwen3:8b
#
# openai_compatible — OpenAI and other OpenAI-compatible APIs
#   LLM_PROVIDER=openai_compatible
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-5.5
#   LLM_API_KEY=
#
# anthropic — Anthropic Messages API 
#   LLM_PROVIDER=anthropic
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   LLM_API_KEY=

# Assets (logical symbols; full catalog in src/config/assets.ts)
# Option A default — enable optional yield tokens by adding cbETH,wstETH,rETH
ASSET_TO_ACCUMULATE=BTC
ASSET_TRADEABLE=BTC,ETH,SOL,USDC,EURC,LINK
ASSET_STARTING=USDC

# Live trading (Phase 2+ — deposits & withdrawals)
# LIVE_MIN_DEPOSIT_USD=1000
# Mainnet defaults:
# DEPOSIT_RPC_URL=https://mainnet.base.org
# DEPOSIT_CHAIN_ID=8453
# Base Sepolia testnet example:
# DEPOSIT_RPC_URL=https://sepolia.base.org
# DEPOSIT_CHAIN_ID=84532
# (USDC contract resolves automatically to Circle testnet USDC on Sepolia)
# WALLET_ENCRYPTION_KEY=  # 64-char hex (32 bytes); required to create live portfolios
# ZEROX_API_KEY=          # 0x Swap API key; required for live DEX execution
# LIVE_MAX_SLIPPAGE_BPS=100   # Max slippage per swap (default 1%)
# LIVE_GAS_BOOTSTRAP_USD=3    # USDC swapped to ETH when wallet has no gas
# CDP_PAYMASTER_RPC_URL=      # Coinbase CDP bundler+paymaster; enables smart accounts (no ETH needed)
# CDP_GAS_PAYMENT_MODE=usdc    # usdc (default) = user pays gas from portfolio USDC; sponsor = you pay via CDP
# CATEGORY_MAX_RISK_ON_FRACTION=0.85  # Max share of categorized assets in risk_on bucket
# WITHDRAWAL_PROFIT_FEE_BPS=500
# WITHDRAWAL_TREASURY_ADDRESS=0x...  # Required for live /liquidate

# Storage (Phase 2+)
DATABASE_PATH=data/accumula.db
# Daily macro briefing job uses a separate env file: cp .env.macro.example .env.macro
# (OpenAI web search). Same DATABASE_PATH so briefings are visible to trading runs.

# Market data (Phase 2+)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

TELEGRAM_BOT_TOKEN=
# Optional: operator admin mirror for run reports and daily summaries.
# When set, copies each user's notifications here (requires TELEGRAM_BOT_TOKEN).
# Onboarded users receive messages at their own Telegram chat id via the bot.
TELEGRAM_CHAT_ID=

CLOUDAMQP_URL=

PREDICTION_MARKETS_ENABLED=true
SOCIAL_MEDIA_ENABLED=true