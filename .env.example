# Copy to .env and fill in values. Never commit .env.

# Exchange API (Phase 4 — live trading)
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=

# Local LLM (Phase 1+)
# LLM_BASE_URL=http://127.0.0.1:11434

# BASE TOKEN 
BASE_TOKEN=BTC

# ASSETS - must map to a valid asset on the exchange and coingecko api
TRADEABLE_ASSETS=BTC,ETH,SOL,USDC