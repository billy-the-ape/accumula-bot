# Copy to .env and fill in values. Never commit .env.

# Exchange API (Phase 4 — live trading)
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=

# LLM provider (Phase 1+)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen3:8b
# LLM_REQUEST_TIMEOUT_MS=1800000  # 30 minutes (default); raise for slow local models
# LLM_TEMPERATURE=0.2             # lower = more deterministic JSON (default: 0.2)
# LLM_API_KEY=
#
# openai_compatible — Ollama, OpenAI, and other OpenAI-compatible APIs
#   Ollama (local): LLM_BASE_URL=http://127.0.0.1:11434
#   OpenAI:         LLM_BASE_URL=https://api.openai.com/v1
#
# anthropic — Anthropic Messages API (requires LLM_API_KEY)
#   LLM_PROVIDER=anthropic
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-3-5-sonnet-20241022

# Assets
ASSET_TO_ACCUMULATE=BTC
ASSET_TRADEABLE=BTC,ETH,SOL,USDC
ASSET_STARTING=USDC

# Storage (Phase 2+)
# DATABASE_PATH=data/accumula.db

# Market data (Phase 2+)
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# COINGECKO_API_KEY=

# Telegram notifications (optional — both required to enable)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
