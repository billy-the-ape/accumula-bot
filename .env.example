# Copy to .env and fill in values. Never commit .env.

# Exchange API (Phase 4 — live trading)
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=

# LLM provider (Phase 1+)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen3:8b
# LLM_REQUEST_TIMEOUT_MS=1800000  # 30 minutes (default); raise for slow local models
# LLM_TEMPERATURE=0.2             # lower = more deterministic JSON (default: 0.2)
# LLM_CONTEXT_TOKENS=32768        # Ollama num_ctx — input context window (default: 32768)
# LLM_MAX_OUTPUT_TOKENS=4096        # max response length incl. thinking (default: 4096)
# LLM_API_KEY=
#
# openai_compatible — Ollama, OpenAI, and other OpenAI-compatible APIs
#   Ollama (local): LLM_BASE_URL=http://127.0.0.1:11434
#   OpenAI:         LLM_BASE_URL=https://api.openai.com/v1
#
# anthropic — Anthropic Messages API (requires LLM_API_KEY)
#   LLM_PROVIDER=anthropic
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-3-5-sonnet-20241022

# Assets
ASSET_TO_ACCUMULATE=BTC
ASSET_TRADEABLE=BTC,ETH,SOL,USDC
ASSET_STARTING=USDC

# Storage (Phase 2+)
# DATABASE_PATH=data/accumula.db

# Market data (Phase 2+)
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# COINGECKO_API_KEY=

# Telegram notifications (optional — both required to enable)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Twitter search AMQP (required when SOCIAL_MEDIA_ENABLED=true)
# CLOUDAMQP_URL=
# TWITTER_SEARCH_STRING=
# TWITTER_SEARCH_MAX_PAGES=10

# Prediction markets (optional — read-only signal from Kalshi + Polymarket)
# Off by default; set to true/1 to add a directional-score section to the LLM
# context. Builds an implied price distribution from several ladder rungs near
# spot (requires CoinGecko reachable via COINGECKO_BASE_URL above).
# PREDICTION_MARKETS_ENABLED=false
# PREDICTION_MARKETS_HORIZON_HOURS=24
# PREDICTION_MARKETS_NORMALIZATION_BAND_PCT=0.05
# PREDICTION_MARKETS_MAX_RUNGS=6
# PREDICTION_MARKETS_MIN_RUNGS=3
# PREDICTION_MARKETS_MIN_RUNG_LIQUIDITY_USD=1000
# KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
# POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Social media (optional — Twitter/X via AMQP; off by default)
# When enabled, each run makes TWO LLM calls: (1) filter/analyze posts,
# (2) portfolio outlook. Reuses LLM_* settings above. Requires CLOUDAMQP_URL.
# SOCIAL_MEDIA_ENABLED=false
# TWITTER_SEARCH_STRING=
# TWITTER_SEARCH_MAX_PAGES=10